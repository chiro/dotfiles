{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "600000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "45000"
  },
  "permissions": {
    "allow": [
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(cargo *)",
      "Bash(cargo-*)",
      "Bash(rustup *)",
      "Bash(make *)",
      "Bash(uv *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)"
    ]
  }
}
